<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="鈿欙笍 璁剧疆"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:paddingBottom="16dp" />

        <!-- 杩炴帴璁剧疆 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="馃寪 杩炴帴璁剧疆"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1976D2" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="鏈嶅姟绔湴鍧€锛堢兢鏅栵級"
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:layout_marginTop="12dp" />

                <EditText
                    android:id="@+id/etServerUrl"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="http://192.168.1.10:8080"
                    android:inputType="textUri"
                    android:background="@drawable/edittext_bg"
                    android:padding="12dp"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="榛樿璁惧鍚嶇О"
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:layout_marginTop="12dp" />

                <EditText
                    android:id="@+id/etDeviceId"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="骞虫澘01"
                    android:background="@drawable/edittext_bg"
                    android:padding="12dp"
                    android:layout_marginTop="4dp" />

                <Button
                    android:id="@+id/btnTestConnection"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="娴嬭瘯杩炴帴"
                    android:layout_marginTop="12dp" />

                <TextView
                    android:id="@+id/tvConnectionResult"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="13sp"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 瀵嗙爜淇敼 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="馃攼 淇敼瀵嗙爜"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1976D2" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="鍘熷瘑鐮?
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:layout_marginTop="12dp" />

                <EditText
                    android:id="@+id/etOldPassword"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="涓嶄慨鏀硅鐣欑┖"
                    android:inputType="textPassword"
                    android:background="@drawable/edittext_bg"
                    android:padding="12dp"
                    android:layout_marginTop="4dp" />

                <EditText
                    android:id="@+id/etNewPassword"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="鏂板瘑鐮侊紙4浣嶄互涓婏級"
                    android:inputType="textPassword"
                    android:background="@drawable/edittext_bg"
                    android:padding="12dp"
                    android:layout_marginTop="8dp" />

                <EditText
                    android:id="@+id/etConfirmNewPassword"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="纭鏂板瘑鐮?
                    android:inputType="textPassword"
                    android:background="@drawable/edittext_bg"
                    android:padding="12dp"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/btnSaveSettings"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="馃捑 淇濆瓨璁剧疆"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#4CAF50"
            android:layout_marginTop="16dp" />

    </LinearLayout>
</ScrollView>
